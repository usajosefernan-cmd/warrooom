# ==================================================
# CONFIGURACIÓN DE AI WAR ROOM
# ==================================================

# Proveedor por defecto de IA (openrouter, anthropic, mock)
AI_DEFAULT_PROVIDER=openrouter

# Modelos recomendados para OpenRouter (Prioridad Modelos Free/Low-Cost)
# Cambia estos si deseas usar modelos específicos
AI_MODEL_ORCHESTRATOR=meta-llama/llama-3-8b-instruct:free
AI_MODEL_FAST=google/gemma-2-9b-it:free
AI_MODEL_REVIEWER=meta-llama/llama-3-8b-instruct:free
AI_MODEL_RESEARCH=google/gemma-2-9b-it:free

# Habilitar modelos gratuitos (true/false)
AI_USE_FREE_MODELS=true

# Coste máximo permitido por ejecución de debate en USD (seguridad de coste)
AI_MAX_COST_PER_RUN=0.10

# Timeout de llamadas de IA en milisegundos
AI_TIMEOUT_MS=45000

# ==================================================
# CLAVES DE API (Servidor/Backend únicamente)
# ==================================================
# IMPORTANTE: Nunca pongas NEXT_PUBLIC_ delante de estas claves.
# Nunca las expongas en el navegador ni las guardes en bases de datos.

# OpenRouter API Key (Acceso a modelos free/low-cost)
OPENROUTER_API_KEY=tu_openrouter_api_key_aquí

# Anthropic API Key (Claude)
ANTHROPIC_API_KEY=tu_anthropic_api_key_aquí

# Gemini / Google API Key
GEMINI_API_KEY=tu_gemini_api_key_aquí
GOOGLE_API_KEY=tu_google_api_key_aquí

# Supabase (Preparado para migración futura)
SUPABASE_URL=tu_supabase_url_aquí
SUPABASE_ANON_KEY=tu_supabase_anon_key_aquí
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key_aquí
DATABASE_URL=tu_postgresql_connection_string_aquí
